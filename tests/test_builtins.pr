/* Test built-in functions */

let pass = 0
let fail = 0

func assert(label, got, expected) {
    if got == expected {
        print("PASS:", label)
        pass += 1
    } else {
        print("FAIL:", label, "  got:", got, "expected:", expected)
        fail += 1
    }
}

/* Math */
assert("abs(-5)", abs(-5), 5)
assert("abs(5)",  abs(5),  5)
assert("sqrt(9)", sqrt(9), 3.0)
assert("floor(3.9)", floor(3.9), 3)
assert("ceil(3.1)",  ceil(3.1),  4)
assert("round(3.567,2)", round(3.567, 2), 3.57)
assert("max([1,5,2])", max([1,5,2]), 5)
assert("min([1,5,2])", min([1,5,2]), 1)
assert("sum([1,2,3])", sum([1,2,3]), 6)

/* Range */
assert("range(3)", range(3), [0,1,2])
assert("range(1,4)", range(1,4), [1,2,3])
assert("range(0,6,2)", range(0,6,2), [0,2,4])

/* Strings */
assert("trim", trim("  hi  "), "hi")
assert("upper", upper("hello"), "HELLO")
assert("lower", lower("WORLD"), "world")
assert("len str", len("hello"), 5)
assert("replace", replace("hello", "l", "r"), "herro")
assert("startsWith", startsWith("hello", "he"), true)
assert("endsWith",   endsWith("hello", "lo"),   true)
assert("contains",   contains("hello", "ell"),  true)
assert("indexOf",    indexOf("hello", "l"),      2)
assert("padLeft",    padLeft("5", 3, "0"),       "005")
assert("padRight",   padRight("5", 3, "0"),      "500")
assert("repeat",     repeat("ab", 3),            "ababab")

/* Arrays */
assert("sorted", sorted([3,1,2]), [1,2,3])
assert("unique", unique([1,2,1,3,2]), [1,2,3])
assert("first", first([10,20,30]), 10)
assert("last",  last([10,20,30]),  30)
assert("compact", compact([1, null, 2, null, 3]), [1,2,3])
assert("indexOf arr", indexOf([10,20,30], 20), 1)

/* Type conversion */
assert("int('42')",   int("42"),   42)
assert("float('3.14')", float("3.14"), 3.14)
assert("str(42)",     str(42),     "42")
assert("bool(1)",     bool(1),     true)
assert("bool(0)",     bool(0),     false)

/* Chr/Ord */
assert("chr(65)", chr(65), "A")
assert("ord('A')", ord("A"), 65)

/* Hex/Bin/Oct */
assert("hex(255)", hex(255), "0xff")
assert("bin(10)", bin(10), "0b1010")

/* Enumerate */
let en = enumerate(["a","b","c"])
assert("enumerate[0]", en[0], [0,"a"])
assert("enumerate[1]", en[1], [1,"b"])

/* Zip */
let z = zip([1,2,3], ["a","b","c"])
assert("zip[0]", z[0], [1,"a"])
assert("zip[2]", z[2], [3,"c"])

/* all/any */
assert("all true",  all([true, true, true]), true)
assert("all false", all([true, false, true]), false)
assert("any true",  any([false, true, false]), true)
assert("any false", any([false, false]), false)

print("\nResults:", pass, "passed,", fail, "failed")
