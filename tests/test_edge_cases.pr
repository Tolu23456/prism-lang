/* Edge case tests for Prism — boundary conditions, error paths, and tricky behavior */

let pass = 0
let fail = 0

func assert(label, got, expected) {
    if got == expected {
        pass += 1
    } else {
        print("FAIL:", label, "  got:", got, "expected:", expected)
        fail += 1
    }
}

func assert_true(label, cond) {
    if cond { pass += 1 }
    else { print("FAIL:", label); fail += 1 }
}

/* ── String edge cases ─────────────────────────────────────── */
assert("empty string len",     len(""),         0)
assert("single char",          "a"[0],          "a")
assert("string concat empty",  "hi" + "",       "hi")
assert("string repeat 0",      repeat("x", 0),  "")
assert("string repeat 1",      repeat("x", 1),  "x")
assert("upper empty",          upper(""),        "")
assert("lower empty",          lower(""),        "")
assert("trim spaces",          trim("  hi  "),   "hi")
assert("trim only spaces",     trim("    "),     "")
assert("split empty sep",      len(split("abc","")), 3)
assert("split no match",       split("abc","z"), ["abc"])
assert("join empty",           join(",", []),    "")
assert("join single",          join(",", ["a"]), "a")
assert("replace no match",     replace("hi","x","y"), "hi")
assert("replace all",          replace("aaa","a","b"), "bbb")

/* ── Array edge cases ─────────────────────────────────────── */
let arr = []
assert("empty array len",  len(arr),  0)
push(arr, 1)
push(arr, 2)
push(arr, 3)
assert("push len",         len(arr),  3)
assert("neg index -1",     arr[-1],   3)
assert("neg index -2",     arr[-2],   2)
assert("neg index -3",     arr[-3],   1)

let sliced = arr[0:2]
assert("slice [0:2]",      sliced,    [1,2])
let sliced2 = arr[1:]
assert("slice [1:]",       sliced2,   [2,3])
let sliced3 = arr[:2]
assert("slice [:2]",       sliced3,   [1,2])

/* ── Dict edge cases ─────────────────────────────────────── */
let d = {}
assert("empty dict len",   len(d),    0)
d["a"] = 1
d["b"] = 2
assert("dict set/get",     d["a"],    1)
d["a"] = 99
assert("dict overwrite",   d["a"],    99)
assert("dict len",         len(d),    2)

/* ── Numeric edge cases ─────────────────────────────────────── */
assert("int max 64-bit safe", 9007199254740992,        9007199254740992)
assert("negative zero",       0 == -0,                  true)
assert("float precision",     round(0.1 + 0.2, 1),      0.3)
assert("int div truncate",    7 / 2,                     3.5)
assert("floor div neg",       -7 // 2,                   -4)
assert("mod negative",        7 % -3,                    1)
assert("pow zero base",       0 ** 0,                    1.0)
assert("pow neg exponent",    2.0 ** -1,                 0.5)

/* ── Boolean edge cases ─────────────────────────────────────── */
assert("bool 0 falsy",    bool(0),       false)
assert("bool 1 truthy",   bool(1),       true)
assert("bool empty str",  bool(""),      false)
assert("bool null",       bool(null),    false)
assert("bool empty arr",  bool([]),      false)
assert("bool empty dict", bool({}),      false)
assert("bool 0.0 falsy",  bool(0.0),    false)
assert("bool non-zero",   bool(42),      true)
assert("bool non-empty",  bool("x"),     true)

/* ── Null coalescing chains ────────────────────────────────── */
let n1 = null
let n2 = null
let n3 = "found"
let chain = n1 ?? n2 ?? n3
assert("null chain",      chain,         "found")

let early = "early"
let chain2 = early ?? null ?? "late"
assert("null chain early exit", chain2,  "early")

/* ── Type coercion ──────────────────────────────────────────── */
assert("int to str",      str(42),       "42")
assert("float to str",    str(3.14),     "3.14")
assert("bool to str",     str(true),     "true")
assert("null to str",     str(null),     "null")
assert("str to int",      int("123"),    123)
assert("str to float",    float("1.5"),  1.5)
assert("float to int",    int(3.9),      3)

/* ── Recursive edge cases ────────────────────────────────────── */
func factorial(n) {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}
assert("factorial 0",  factorial(0),  1)
assert("factorial 1",  factorial(1),  1)
assert("factorial 5",  factorial(5),  120)
assert("factorial 10", factorial(10), 3628800)

/* ── Closure edge cases ─────────────────────────────────────── */
func make_adder(n) {
    func add(x) { return x + n }
    return add
}
let add5 = make_adder(5)
let add10 = make_adder(10)
assert("closure add5",   add5(3),    8)
assert("closure add10",  add10(3),   13)
assert("closures independent", add5(add10(1)), 16)

/* ── Set operations ─────────────────────────────────────────── */
let s1 = {1, 2, 3, 4}
let s2 = {3, 4, 5, 6}
let union_set    = s1 | s2
let inter_set    = s1 & s2
let diff_set     = s1 ^ s2
assert_true("union len",  len(union_set) == 6)
assert_true("inter len",  len(inter_set) == 2)
assert("contains 3 in inter", 3 in inter_set, true)
assert("contains 5 in diff",  5 in diff_set,  true)
assert("contains 1 in diff",  1 in diff_set,  true)

/* ── For-in edge cases ─────────────────────────────────────── */
let sum_empty = 0
for x in [] { sum_empty += x }
assert("for-in empty",    sum_empty,   0)

let sum_single = 0
for x in [42] { sum_single += x }
assert("for-in single",   sum_single,  42)

let str_chars = ""
for ch in "abc" { str_chars = str_chars + ch }
assert("for-in string",   str_chars,   "abc")

/* ── While edge cases ────────────────────────────────────────── */
let n = 0
while false { n += 1 }
assert("while false never executes", n, 0)

let m = 5
while m > 0 { m -= 1 }
assert("while counts down", m, 0)

print("\nResults:", pass, "passed,", fail, "failed")
if fail == 0 { print("[PASS] test_edge_cases") }
else { print("[FAIL] test_edge_cases") }
